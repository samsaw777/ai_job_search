# === LLM API Keys ===
# Groq (free tier) — used for parsing + decision making
GROQ_API_KEY=gsk_your_key_here

# Google Gemini (free tier) — used for match scoring + skill gap analysis
GOOGLE_API_KEY=AIza_your_key_here

# OpenAI (paid, $5 budget) — used for cold email drafts + resume rewrites
OPENAI_API_KEY=sk-your_key_here

# === Google Sheets (for "Apply & Save" feature) ===
# 1. Go to console.cloud.google.com → create a project → enable Google Sheets API
# 2. Create a Service Account → create a JSON key → download it
# 3. Share your tracking spreadsheet with the service account email (editor role)
# 4. Fill in the path to the key file and the spreadsheet ID below
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# === Server ===
HOST=0.0.0.0
PORT=8000
